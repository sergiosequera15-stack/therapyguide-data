  "calculators": [
    {
      "id": "cockcroft_gault_clcr_rccc",
      "title": "ClCr estimado (Cockcroft-Gault)",
      "category": "renal_function_for_dose_adjustment",
      "type": "renal_function",
      "enabled": true,
      "validated": true,
      "clinicalDecisionSupportAllowed": false,
      "therapeuticRecommendationAllowed": false,
      "automaticDoseAdjustmentAllowed": false,
      "drug": null,
      "inputs": [
        {
          "id": "ageYears",
          "label": "Edad",
          "unit": "años",
          "type": "number",
          "required": true,
          "min": 1,
          "max": 120
        },
        {
          "id": "weightKg",
          "label": "Peso",
          "unit": "kg",
          "type": "number",
          "required": true,
          "min": 1,
          "max": 300
        },
        {
          "id": "serumCreatinineMgDl",
          "label": "Creatinina sérica",
          "unit": "mg/dL",
          "type": "number",
          "required": true,
          "min": 0.1,
          "max": 20
        },
        {
          "id": "sex",
          "label": "Sexo",
          "type": "select",
          "required": true,
          "options": [
            {
              "value": "male",
              "label": "Varón"
            },
            {
              "value": "female",
              "label": "Mujer"
            }
          ]
        }
      ],
      "formula": {
        "kind": "cockcroft_gault",
        "maleExpression": "((140 - ageYears) * weightKg) / (serumCreatinineMgDl * 72)",
        "femaleMultiplier": 0.85,
        "rounding": {
          "decimals": 1,
          "mode": "nearest"
        }
      },
      "output": {
        "unit": "mL/min",
        "label": "Aclaramiento de creatinina estimado",
        "precision": 1
      },
      "warnings": [
        "Herramienta de cálculo. No ajusta automáticamente dosis de antimicrobianos.",
        "Usar solo si la fórmula Cockcroft-Gault es adecuada para el contexto clínico. Revisar peso usado e interpretación clínica."
      ],
      "source": {
        "sourceName": "RCCC",
        "sourceCalculatorTitle": "Indice de Filtración Glomerular Clcr estimado (Cockcroft-Gault)",
        "sourceUrl": "https://www.rccc.eu/Nefro/IFG.html",
        "sourceText": "ClCr-varón = ((140 - edad años) x Peso kg) / Cr sérica x 72; ClCr-Mujer = (ClCr varón) x 0.85",
        "reference": "Cockroft DW, Gault MH. Prediction of creatinine clearance from serum creatinine. Nephron. 1976;16(1):31-41."
      },
      "validation": {
        "status": "validated",
        "validatedAt": "2026-06-26T00:00:00Z",
        "testCases": [
          {
            "id": "male_60y_70kg_cr1",
            "inputs": {
              "ageYears": 60,
              "weightKg": 70,
              "serumCreatinineMgDl": 1,
              "sex": "male"
            },
            "expectedValue": 77.8,
            "expectedUnit": "mL/min",
            "tolerance": 0.05
          },
          {
            "id": "female_60y_70kg_cr1",
            "inputs": {
              "ageYears": 60,
              "weightKg": 70,
              "serumCreatinineMgDl": 1,
              "sex": "female"
            },
            "expectedValue": 66.1,
            "expectedUnit": "mL/min",
            "tolerance": 0.05
          },
          {
            "id": "invalid_zero_creatinine",
            "inputs": {
              "ageYears": 60,
              "weightKg": 70,
              "serumCreatinineMgDl": 0,
              "sex": "male"
            },
            "expectError": true
          }
        ]
      }
    },
    {
      "id": "bsa_mosteller",
      "title": "Superficie corporal estimada (Mosteller)",
      "category": "anthropometry",
      "type": "body_surface_area",
      "enabled": true,
      "validated": true,
      "clinicalDecisionSupportAllowed": false,
      "therapeuticRecommendationAllowed": false,
      "automaticDoseAdjustmentAllowed": false,
      "drug": null,
      "inputs": [
        {
          "id": "heightCm",
          "label": "Talla",
          "unit": "cm",
          "type": "number",
          "required": true,
          "min": 30,
          "max": 250
        },
        {
          "id": "weightKg",
          "label": "Peso",
          "unit": "kg",
          "type": "number",
          "required": true,
          "min": 1,
          "max": 300
        }
      ],
      "formula": {
        "kind": "bsa_mosteller",
        "expression": "sqrt((heightCm * weightKg) / 3600)",
        "rounding": {
          "decimals": 2,
          "mode": "nearest"
        }
      },
      "output": {
        "unit": "m²",
        "label": "Superficie corporal estimada",
        "precision": 2
      },
      "warnings": [
        "Herramienta antropométrica. No recomienda tratamiento ni ajusta dosis automáticamente.",
        "Interpretar el resultado en el contexto clínico y de la fuente que lo requiera."
      ],
      "source": {
        "sourceName": "Mosteller RD",
        "sourceCalculatorTitle": "Simplified calculation of body-surface area",
        "sourceUrl": "https://www.nejm.org/doi/full/10.1056/NEJM198710223171717",
        "sourceText": "BSA (m²) = sqrt((height cm x weight kg) / 3600)",
        "reference": "Mosteller RD. Simplified calculation of body-surface area. N Engl J Med. 1987;317:1098."
      },
      "validation": {
        "status": "validated",
        "validatedAt": "2026-07-01T00:00:00Z",
        "testCases": [
          {
            "id": "adult_170cm_70kg",
            "inputs": {
              "heightCm": 170,
              "weightKg": 70
            },
            "expectedValue": 1.82,
            "expectedUnit": "m²",
            "tolerance": 0.005
          },
          {
            "id": "adult_160cm_60kg",
            "inputs": {
              "heightCm": 160,
              "weightKg": 60
            },
            "expectedValue": 1.63,
            "expectedUnit": "m²",
            "tolerance": 0.005
          },
          {
            "id": "invalid_zero_height",
            "inputs": {
              "heightCm": 0,
              "weightKg": 70
            },
            "expectError": true
          }
        ]
      }
    },
